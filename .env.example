APP_ENV=development

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=video_shop
POSTGRES_USER=video_shop
POSTGRES_PASSWORD=change_me

REDIS_URL=redis://redis:6379/0

# Schema management (see docs/db-least-privilege.md). Defaults keep the
# current runtime-DDL behavior; only change these after running the Alembic
# migration and creating the restricted DB role.
DB_AUTO_SCHEMA=1
RUN_MIGRATIONS=0
ALEMBIC_DATABASE_URL=

BOT_TOKEN=
BOT_USERNAME=

TELEGRAM_WEBAPP_URL=
BACKEND_PUBLIC_URL=
MEDIA_PUBLIC_URL=
ADMIN_PUBLIC_URL=

JWT_SECRET=
INITDATA_MAX_AGE_SECONDS=86400

ADMIN_JWT_SECRET=
ADMIN_DEFAULT_EMAIL=
ADMIN_DEFAULT_PASSWORD=
ADMIN_DEFAULT_TELEGRAM_ID=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=

CLOUDFLARE_TUNNEL_TOKEN=

MAX_DISCOUNT_PERCENT=50
DEFAULT_LANGUAGE=en

# Sentry error monitoring. Leave empty to disable everywhere.
# Backend + bot read SENTRY_DSN. Frontends need VITE_SENTRY_DSN at BUILD time (in CI).
SENTRY_DSN=
VITE_SENTRY_DSN=

INTERNAL_API_URL=http://backend:8000
INTERNAL_API_SECRET=change-me-internal-secret

# Cloudflare R2 media storage (S3-compatible). Set all five to serve media from
# the CDN instead of the local volume. Leave empty to keep local-disk uploads.
#   R2_ENDPOINT_URL   = https://<account-id>.r2.cloudflarestorage.com
#   R2_PUBLIC_BASE_URL= the bucket's connected custom domain (e.g. https://media.example.com)
R2_ENDPOINT_URL=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_PUBLIC_BASE_URL=
